{
  "$id": "https://revit-suite/schemas/shared_coordinates_report.schema.json",
  "title": "SharedCoordinatesReportInput",
  "x-version": "1.0.0",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "default": "1.0.0"
    },
    "includeLinkedModels": {
      "type": "boolean",
      "default": true,
      "description": "Whether to include shared coordinate information from loaded Revit link instances."
    },
    "precision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 6,
      "default": 3,
      "description": "Decimal precision for coordinate values (feet)."
    },
    "anglePrecision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 6,
      "default": 4,
      "description": "Decimal precision for angular values (degrees)."
    },
    "maxPreviewRows": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20,
      "default": 5,
      "description": "Number of records to include in the log preview payload."
    }
  },
  "additionalProperties": false
}
